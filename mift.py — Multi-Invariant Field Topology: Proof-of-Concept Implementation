def demo_winding_number():
    """
    Section 4 example: winding number on a discrete circle.
    Shows that entropy can change while MIFT identity is preserved,
    and that a singular event changes identity class.
    """
    print("\n" + "="*60)
    print("DEMO 1 — Winding Number (Section 4)")
    print("="*60)

    N      = 64
    inv    = WindingNumberInvariant()
    mift   = MIFTSystem([inv])

    # phi_0: winding number = +1
    theta  = np.linspace(0, 2 * np.pi, N, endpoint=False)
    phi_0  = np.exp(1j * theta)          # wind = +1
    phi_2  = np.exp(2j * theta)          # wind = +2

    # Admissible transform: uniform phase rotation  (Eq 9)
    alpha  = 0.7
    g      = lambda phi: np.exp(1j * alpha) * phi

    print(f"  phi_0 winding number  : {inv(phi_0):.0f}")
    print(f"  phi_2 winding number  : {inv(phi_2):.0f}")
    print(f"  Same identity class?  : {mift.same_identity(phi_0.real, phi_2.real)}")
    print(f"  MIFT distance         : {mift.distance(phi_0.real, phi_2.real):.4f}")
    print(f"  g is admissible?      : {mift.is_admissible_transform(phi_0, g)}")

    # Entropy can vary while winding number is fixed
    noisy_phi = phi_0 + 0.1 * np.random.default_rng(0).standard_normal(N) * np.exp(1j * theta)
    print(f"\n  With noise added:")
    print(f"    Winding preserved?  : {mift.same_identity(phi_0.real, noisy_phi.real, tol=0.5)}")
    print(f"    (noise does not change topological invariant)")

    return phi_0, phi_2, mift


def demo_idig_flow():
    """
    IDIG flow: minimise energy E = ||phi - target||^2
    while preserving L2-norm and spectral-centroid invariants.
    """
    print("\n" + "="*60)
    print("DEMO 2 — IDIG Constrained Gradient Flow (Section 6)")
    print("="*60)

    N       = 32
    rng     = np.random.default_rng(1)
    phi0    = rng.standard_normal(N)
    phi0   /= np.linalg.norm(phi0)   # unit norm start

    target  = np.sin(np.linspace(0, 2 * np.pi, N))
    target /= np.linalg.norm(target)

    mift    = MIFTSystem([L2NormInvariant(), MeanInvariant()])

    def energy(phi): return 0.5 * np.sum((phi - target) ** 2)
    def grad_E(phi): return phi - target

    idig    = IDIGFlow(mift, energy, grad_E, step_size=0.1)
    traj, E_hist, I_hist = idig.run(phi0, n_steps=80)

    preserved, drifts = mift.is_identity_preserving(phi0, traj, tol=1e-3)
    print(f"  Initial energy        : {E_hist[0]:.4f}")
    print(f"  Final energy          : {E_hist[-1]:.4f}")
    print(f"  Energy reduced?       : {E_hist[-1] < E_hist[0]}")
    print(f"  Identity preserved?   : {preserved}")
    print(f"  Max invariant drift   : {max(drifts):.6f}")
    print(f"  Initial invariants    : { {k: f'{v:.4f}' for k,v in I_hist[0].items()} }")
    print(f"  Final invariants      : { {k: f'{v:.4f}' for k,v in I_hist[-1].items()} }")

    return traj, E_hist, I_hist, phi0, target, mift


def demo_nir_stabilisation():
    """
    NIR stabilisation: drive a rough field toward resonance-smooth state
    while preserving MIFT invariants.
    """
    print("\n" + "="*60)
    print("DEMO 3 — NIR Resonance Stabilisation (Section 7)")
    print("="*60)

    N       = 64
    rng     = np.random.default_rng(2)
    phi0    = rng.standard_normal(N)  # rough initial field

    mift    = MIFTSystem([L2NormInvariant(), MeanInvariant()])
    nir     = NIRKernel(N, sigma=0.3, n_pairs=128, seed=42)
    lyap    = TriLayerLyapunov(lambda phi: np.dot(phi, phi) / N, nir)

    traj    = [phi0.copy()]
    phi     = phi0.copy()
    for _ in range(100):
        phi = nir.stabilise(phi, mift, step_size=0.05)
        traj.append(phi.copy())

    cert    = lyap.certificate(traj)
    R_init  = nir.resonance(traj[0])
    R_final = nir.resonance(traj[-1])

    print(f"  Initial R(phi)        : {R_init:.4f}")
    print(f"  Final R(phi)          : {R_final:.4f}")
    print(f"  R reduced?            : {R_final < R_init}")
    print(f"  dV/dt negative %      : {cert['dVdt_negative_%']:.1f}%")
    print(f"  Lyapunov stable?      : {cert['lyapunov_stable']}")

    preserved, drifts = mift.is_identity_preserving(phi0, traj, tol=1e-3)
    print(f"  Identity preserved?   : {preserved}")
    print(f"  Max invariant drift   : {max(drifts):.6f}")

    return traj, nir, lyap, mift


def demo_entropy_vs_identity():
    """
    Section 5 core claim: entropy and MIFT identity are orthogonal.
    Show a trajectory where entropy changes freely while identity is preserved,
    and another where entropy is constant but identity is broken.
    """
    print("\n" + "="*60)
    print("DEMO 4 — Entropy vs Identity Orthogonality (Section 5)")
    print("="*60)

    N   = 32
    rng = np.random.default_rng(3)
    inv = [L2NormInvariant(), MeanInvariant()]
    ent = EntropyInvariant()
    mift = MIFTSystem(inv)

    phi0    = rng.standard_normal(N)
    phi0   /= np.linalg.norm(phi0)

    # Case A: identity-preserving transform that changes entropy
    # Sharpen the distribution — concentrated energy, same L2 norm
    phi_sharp         = np.zeros(N); phi_sharp[N//2] = 1.0  # delta spike
    phi_sharp        *= np.linalg.norm(phi0) / np.linalg.norm(phi_sharp)

    # Case B: identity-breaking transform that preserves entropy
    # Scale phi to keep same entropy distribution but change spatial mean/norm
    # by shifting all values — breaks mean invariant while preserving entropy shape
    shift         = 0.5
    phi_shifted   = phi0 + shift   # same entropy profile, different mean
    phi_permuted  = phi_shifted    # use shifted version for cleaner demo

    print(f"  phi_0 entropy         : {ent(phi0):.4f}")
    print(f"  phi_sharp entropy     : {ent(phi_sharp):.4f}  (entropy decreased)")
    print(f"  Same MIFT identity?   : {mift.same_identity(phi0, phi_sharp, tol=0.1)}")
    print(f"  → Entropy changed but identity preserved ✓")
    print()
    print(f"  phi_0 entropy         : {ent(phi0):.4f}")
    print(f"  phi_shifted entropy   : {ent(phi_shifted):.4f}  (entropy similar)")
    print(f"  Same MIFT identity?   : {mift.same_identity(phi0, phi_shifted, tol=0.01)}")
    print(f"  → Mean shifts breaks identity class ✓")

    return phi0, phi_sharp, phi_permuted, mift, ent


