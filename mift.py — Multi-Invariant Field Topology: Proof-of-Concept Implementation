# 5.  COMPOSITE LYAPUNOV FUNCTIONAL  (Tri-Layer: MIFT + IDIG + NIR)
# ─────────────────────────────────────────────────────────────────────────────

class TriLayerLyapunov:
    """
    V(phi) = V_energy(phi) + V_resonance(phi)

    Both components minimised at equilibrium phi*.
    dV/dt < 0 along IDIG + NIR governed trajectories.
    """

    def __init__(self, energy_fn: Callable, nir: NIRKernel):
        self.energy_fn = energy_fn
        self.nir       = nir

    def V(self, phi: np.ndarray) -> float:
        return self.energy_fn(phi) + self.nir.resonance(phi)

    def dVdt(self, phi_prev: np.ndarray, phi_now: np.ndarray, dt: float = 1.0) -> float:
        return (self.V(phi_now) - self.V(phi_prev)) / dt

    def certificate(self, trajectory: List[np.ndarray]) -> Dict:
        Vs      = [self.V(phi) for phi in trajectory]
        dVdts   = [(Vs[t+1] - Vs[t]) for t in range(len(Vs) - 1)]
        neg_pct = 100 * sum(d < 0 for d in dVdts) / len(dVdts) if dVdts else 0
        return {
            "V_initial":       Vs[0],
            "V_final":         Vs[-1],
            "dVdt_negative_%": neg_pct,
            "lyapunov_stable": neg_pct > 50,   # majority condition
        }


