# ─────────────────────────────────────────────────────────────────────────────
# 1.  CORE MIFT SYSTEM
# ─────────────────────────────────────────────────────────────────────────────

class Invariant(ABC):
    """Abstract base for a single invariant  Ik : F → R or Z  (Definition 3.1)."""

    @property
    @abstractmethod
    def name(self) -> str: ...

    @abstractmethod
    def __call__(self, phi: np.ndarray) -> float: ...


class MIFTSystem:
    """
    A MIFT system  (M, F, G, I)  operating on discrete state arrays.

    M  — implicit: integer index set {0, …, N-1}
    F  — R^N  (continuous field configurations)
    G  — supplied as a list of transformation callables
    I  — supplied as a list of Invariant instances

    Definition 3.1, Eq (4).
    """

    def __init__(
        self,
        invariants: List[Invariant],
        admissible_transforms: Optional[List[Callable]] = None,
        weights: Optional[np.ndarray] = None,
    ):
        self.invariants = invariants
        self.transforms = admissible_transforms or []
        self._weights = weights  # for MIFT distance metric

    # ── Invariant evaluation ─────────────────────────────────────────────────

    def evaluate(self, phi: np.ndarray) -> Dict[str, float]:
        """Return {invariant_name: value} for a field configuration."""
        return {inv.name: float(inv(phi)) for inv in self.invariants}

    def invariant_vector(self, phi: np.ndarray) -> np.ndarray:
        return np.array([float(inv(phi)) for inv in self.invariants])

    # ── Identity class membership  (Definition 3.2, Eq 5) ───────────────────

    def same_identity(self, phi: np.ndarray, psi: np.ndarray, tol: float = 1e-6) -> bool:
        """True iff phi and psi lie in the same MIFT identity class."""
        return bool(np.allclose(self.invariant_vector(phi),
                                self.invariant_vector(psi), atol=tol))

    # ── MIFT distance metric  (Definition 3.3, Eq 6) ────────────────────────

    def distance(self, phi: np.ndarray, psi: np.ndarray) -> float:
        """
        d_MIFT(phi, psi) = sqrt( sum_k  w_k * (Ik(phi) - Ik(psi))^2 )
        Returns 0 iff phi and psi are in the same identity class.
        """
        diff = self.invariant_vector(phi) - self.invariant_vector(psi)
        w = self._weights if self._weights is not None else np.ones(len(self.invariants))
        return float(np.sqrt(np.dot(w, diff ** 2)))

    # ── Admissibility check  (Eq 4) ──────────────────────────────────────────

    def is_admissible_transform(self, phi: np.ndarray, g: Callable, tol: float = 1e-6) -> bool:
        """Verify that transform g preserves all invariants (Eq 4)."""
        phi_t = g(phi)
        return self.same_identity(phi, phi_t, tol=tol)

    # ── Identity-preserving dynamics check  (Definition 3.4, Eq 7) ──────────

    def is_identity_preserving(
        self,
        phi0: np.ndarray,
        trajectory: List[np.ndarray],
        tol: float = 1e-6,
    ) -> Tuple[bool, List[float]]:
        """
        Check whether a trajectory remains in the MIFT identity class of phi0.
        Returns (all_preserved, list_of_drift_values).
        """
        v0 = self.invariant_vector(phi0)
        drifts = [float(np.max(np.abs(self.invariant_vector(phi) - v0)))
                  for phi in trajectory]
        return all(d <= tol for d in drifts), drifts

    # ── Approximate identity preservation  (Definition 3.5, Eq 8) ───────────

    def approx_identity_preserving(
        self,
        phi0: np.ndarray,
        trajectory: List[np.ndarray],
        epsilons: np.ndarray,
    ) -> Tuple[bool, np.ndarray]:
        """
        Check |Ik(phi_t) - Ik(phi0)| <= epsilon_k  for all k, t.
        Returns (all_within_bounds, max_violation_per_invariant).
        """
        v0 = self.invariant_vector(phi0)
        max_viol = np.zeros(len(self.invariants))
        for phi in trajectory:
            vt = self.invariant_vector(phi)
            max_viol = np.maximum(max_viol, np.abs(vt - v0))
        return bool(np.all(max_viol <= epsilons)), max_viol


# ─────────────────────────────────────────────────────────────────────────────
# 2.  CONCRETE INVARIANTS
# ─────────────────────────────────────────────────────────────────────────────

class L2NormInvariant(Invariant):
    """I(phi) = ||phi||_2 — energy-norm invariant."""
    name = "l2_norm"
    def __call__(self, phi): return float(np.linalg.norm(phi))


class SpectralCentroidInvariant(Invariant):
    """I(phi) = spectral centroid F = sum_k k*rho_k / E."""
    name = "spectral_centroid"
    def __call__(self, phi):
        psi = phi / (np.max(np.abs(phi)) + 1e-12)
        rho = np.abs(np.fft.rfft(psi)) ** 2
        k   = np.arange(len(rho), dtype=float)
        E   = rho.sum() + 1e-12
        return float(np.dot(k, rho) / E)


class MeanInvariant(Invariant):
    """I(phi) = mean(phi) — first-moment invariant."""
    name = "mean"
    def __call__(self, phi): return float(np.mean(phi))


class WindingNumberInvariant(Invariant):
    """
    Winding number of a complex-valued field on a discrete circle.
    For complex phi, counts how many times phase wraps around 2π.
    For real phi, interprets values as phase angles directly.
    (Section 4 example — Eq 9, 10, 11)
    """
    name = "winding_number"

    def __call__(self, phi):
        if np.iscomplexobj(phi):
            angles = np.angle(phi)
        else:
            # Treat real values as a phase field
            angles = phi % (2 * np.pi)
        # Compute total winding as sum of wrapped differences (periodic boundary)
        diffs   = np.diff(np.unwrap(angles))
        total   = diffs.sum()
        return float(np.round(total / (2 * np.pi)))


class TopologicalChargeInvariant(Invariant):
    """
    Discrete topological charge:  Q = (1/2pi) * sum of oriented angle differences.
    Works on 1-D configurations interpreted as phase fields.
    """
    name = "topological_charge"

    def __call__(self, phi):
        angles  = np.angle(np.exp(1j * phi))
        diffs   = np.diff(angles, append=angles[0])  # periodic
        wrapped = (diffs + np.pi) % (2 * np.pi) - np.pi
        return float(np.round(wrapped.sum() / (2 * np.pi)))


class EntropyInvariant(Invariant):
    """Shannon entropy of the normalised |phi|^2 distribution."""
    name = "entropy"

    def __call__(self, phi):
        p = np.abs(phi) ** 2
        p = p / (p.sum() + 1e-12)
        p = p[p > 0]
        return float(-np.sum(p * np.log(p)))


# ─────────────────────────────────────────────────────────────────────────────
# 3.  IDIG — Identity-Constrained Gradient Flow  (Section 6)
# ─────────────────────────────────────────────────────────────────────────────

class IDIGFlow:
    """
    Identity Gradient (IDIG) flow constrained to the MIFT identity manifold.

    Implements Definition 6.1:
      dphi/dt  = X(phi)
      d/dt Ik  = 0  for all k          [identity preserved, Eq 13]
      d/dt E   = -||grad E||^2_proj ≤ 0 [energy dissipating, Eq 14]

    The vector field X is the projection of -grad_E onto the tangent space
    of the identity class (Lagrange-multiplier / nullspace projection form).
    """

    def __init__(
        self,
        mift: MIFTSystem,
        energy: Callable[[np.ndarray], float],
        energy_grad: Callable[[np.ndarray], np.ndarray],
        step_size: float = 0.05,
    ):
        self.mift        = mift
        self.energy      = energy
        self.energy_grad = energy_grad
        self.dt          = step_size

    def _constraint_jacobian(self, phi: np.ndarray, eps: float = 1e-5) -> np.ndarray:
        """
        Numerically compute J[k,n] = dIk/dphi_n  (finite difference).
        Shape: (num_invariants, dim).
        """
        K   = len(self.mift.invariants)
        N   = len(phi)
        J   = np.zeros((K, N))
        v0  = self.mift.invariant_vector(phi)
        for n in range(N):
            phi_p    = phi.copy(); phi_p[n] += eps
            phi_m    = phi.copy(); phi_m[n] -= eps
            J[:, n]  = (self.mift.invariant_vector(phi_p)
                        - self.mift.invariant_vector(phi_m)) / (2 * eps)
        return J

    def _project_onto_tangent_space(self, phi: np.ndarray, v: np.ndarray) -> np.ndarray:
        """
        Project vector v onto the tangent space of the identity class at phi.
        Uses nullspace projection: v_proj = v - J^T (J J^T)^+ J v
        where J is the constraint Jacobian.
        """
        J = self._constraint_jacobian(phi)
        if np.allclose(J, 0):
            return v
        JJT       = J @ J.T
        try:
            JJT_inv = np.linalg.pinv(JJT)
        except np.linalg.LinAlgError:
            return v
        v_proj    = v - J.T @ (JJT_inv @ (J @ v))
        return v_proj

    def step(self, phi: np.ndarray) -> np.ndarray:
        """One IDIG step: projected gradient descent on E, preserving identity."""
        grad_E    = self.energy_grad(phi)
        descent   = -grad_E
        projected = self._project_onto_tangent_space(phi, descent)
        phi_new   = phi + self.dt * projected

        # Re-anchor: correct any residual drift in invariants via Newton step
        # This keeps identity preservation tight without reducing step size
        J   = self._constraint_jacobian(phi)
        v0  = self.mift.invariant_vector(phi)
        v1  = self.mift.invariant_vector(phi_new)
        err = v1 - v0
        if np.linalg.norm(err) > 1e-8:
            JJT = J @ J.T
            try:
                correction = J.T @ np.linalg.solve(JJT + 1e-10 * np.eye(len(v0)), err)
                phi_new   -= correction
            except np.linalg.LinAlgError:
                pass
        return phi_new

    def run(self, phi0: np.ndarray, n_steps: int) -> Tuple[List[np.ndarray], List[float], List[Dict]]:
        """
        Run IDIG flow for n_steps.
        Returns (trajectory, energy_history, invariant_history).
        """
        phi    = phi0.copy()
        traj   = [phi.copy()]
        E_hist = [self.energy(phi)]
        I_hist = [self.mift.evaluate(phi)]

        for _ in range(n_steps):
            phi    = self.step(phi)
            traj.append(phi.copy())
            E_hist.append(self.energy(phi))
            I_hist.append(self.mift.evaluate(phi))

        return traj, E_hist, I_hist


# ─────────────────────────────────────────────────────────────────────────────
# 4.  NIR — Non-Isotropic Resonance Kernel  (Section 7)
# ─────────────────────────────────────────────────────────────────────────────

class NIRKernel:
    """
    Non-Isotropic Resonance kernel  K(x, y) : M × M → R  (Eq 15).

    Implements a symmetric positive-semi-definite RBF kernel with
    non-isotropic bandwidth — i.e. sigma varies across site pairs,
    creating directional resonance preferences.

    The resonance functional R(phi) = (1/2M) sum_m K(i_m, j_m) (phi[i_m] - phi[j_m])^2
    is minimised when phi is locally smooth along high-K directions.
    """

    def __init__(
        self,
        N: int,
        sigma: float = 0.3,
        n_pairs: int = 64,
        seed: int = 42,
        anisotropy: Optional[np.ndarray] = None,
    ):
        self.N        = N
        self.sigma    = sigma
        self.n_pairs  = min(n_pairs, N * (N - 1) // 2)
        rng           = np.random.default_rng(seed)

        # Fixed sparse site-pair sample
        all_i = []
        all_j = []
        for i in range(N):
            for j in range(i + 1, N):
                all_i.append(i); all_j.append(j)
        idx       = rng.choice(len(all_i), size=self.n_pairs, replace=False)
        self.pairs_i = np.array(all_i)[idx]
        self.pairs_j = np.array(all_j)[idx]

        # Non-isotropic bandwidth: multiply per-pair sigma by anisotropy weights
        if anisotropy is None:
            anisotropy = np.ones(self.n_pairs)
        anisotropy = anisotropy[:self.n_pairs]

        # Precompute kernel weights (positive semi-definite by RBF construction)
        d_norm      = np.abs(self.pairs_i - self.pairs_j) / N
        self.K_vals = np.exp(-d_norm ** 2 / (2 * (sigma * anisotropy) ** 2))

    def kernel(self, i: int, j: int) -> float:
        """Evaluate K(i, j) for arbitrary site pair."""
        d = abs(i - j) / self.N
        return float(np.exp(-d ** 2 / (2 * self.sigma ** 2)))

    def resonance(self, phi: np.ndarray) -> float:
        """
        R(phi) = (1/2M) * sum_m K(i_m, j_m) * (phi[i_m] - phi[j_m])^2
        R >= 0;  R = 0 iff phi is uniform (all sites equal).
        """
        diffs = phi[self.pairs_i] - phi[self.pairs_j]
        return float(np.dot(self.K_vals, diffs ** 2) / (2 * self.n_pairs))

    def resonance_gradient(self, phi: np.ndarray) -> np.ndarray:
        """Analytic gradient of R with respect to phi."""
        grad  = np.zeros_like(phi)
        diffs = phi[self.pairs_i] - phi[self.pairs_j]
        weighted = self.K_vals * diffs / self.n_pairs
        np.add.at(grad, self.pairs_i,  weighted)
        np.add.at(grad, self.pairs_j, -weighted)
        return grad

    def stabilise(self, phi: np.ndarray, mift: MIFTSystem,
                  step_size: float = 0.05) -> np.ndarray:
        """
        One NIR stabilisation step: descend on R while preserving MIFT invariants.
        This is the IDIG + NIR combined step (Section 7.2).
        """
        idig = IDIGFlow(mift, self.resonance, self.resonance_gradient, step_size)
        return idig.step(phi)


